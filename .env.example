APP_NAME="NotebookLM API"
APP_ENV="dev"
APP_VERSION="0.1.0"
LOG_LEVEL="INFO"
APP_HOST="0.0.0.0"
APP_PORT="8080"

# Paths
DATA_DIR="data"
JOBS_DIR="data/jobs"
ARTIFACTS_DIR="data/artifacts"
TEMP_DIR="data/tmp"
SQLITE_DB_PATH="data/notebooks.db"
STORAGE_STATE_PATH="data/auth/storage_state.json"
# Alias opcional compativel com integrações legadas
NOTEBOOKLM_STORAGE_STATE_PATH="data/auth/storage_state.json"

# NotebookLM backend: mock | real
NOTEBOOKLM_MODE="real"
NOTEBOOK_OPERATION_TIMEOUT_SECONDS="240"
NOTEBOOK_POLL_INTERVAL_SECONDS="2.0"

# Worker local (MVP)
WORKER_POLL_INTERVAL_SECONDS="0.2"
