APP_NAME="NotebookLM API"
APP_ENV="dev"
APP_VERSION="0.1.0"
LOG_LEVEL="INFO"
APP_HOST="0.0.0.0"
APP_PORT="8080"

# Paths
DATA_DIR="data"
JOBS_DIR="data/jobs"
ARTIFACTS_DIR="data/artifacts"
TEMP_DIR="data/tmp"
SQLITE_DB_PATH="data/notebooks.db"
STORAGE_STATE_PATH="data/auth/storage_state.json"
# Alias opcional compativel com integrações legadas
NOTEBOOKLM_STORAGE_STATE_PATH="data/auth/storage_state.json"

# NotebookLM backend: mock | real
NOTEBOOKLM_MODE="real"
NOTEBOOK_OPERATION_TIMEOUT_SECONDS="240"
NOTEBOOK_POLL_INTERVAL_SECONDS="2.0"

# Worker local (MVP)
WORKER_POLL_INTERVAL_SECONDS="0.2"

# --- Seguranca da API (Onda 5) ---
# Token Bearer exigido nas rotas sensiveis (default-deny). Gere um valor forte
# e mantenha-o secreto (nunca comite um token real).
API_AUTH_TOKEN=""
# APENAS desenvolvimento local: libera as rotas sem token. NUNCA use em producao.
ALLOW_INSECURE_NO_AUTH="false"
# CORS fechado por padrao. Liste as origens permitidas separadas por virgula.
CORS_ALLOW_ORIGINS=""
CORS_ALLOW_METHODS="GET,POST,PUT,DELETE,OPTIONS"
CORS_ALLOW_HEADERS="Authorization,Content-Type,X-NotebookLM-Account-Id"
# So habilite credentials com origens explicitas (jamais com '*').
CORS_ALLOW_CREDENTIALS="false"
